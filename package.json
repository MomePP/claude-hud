{
  "name": "claude-hud",
  "version": "0.8.0",
  "description": "Real-time statusline HUD for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "commands/",
    "scripts/",
    ".claude-plugin/"
  ],
  "scripts": {
    "build": "tsc && esbuild dist/index.js --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --allow-overwrite --minify --keep-names --legal-comments=none && rm -f dist/index.js.map",
    "dev": "tsc --watch",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && c8 --reporter=text --reporter=lcov node --test",
    "test:update-snapshots": "UPDATE_SNAPSHOTS=1 npm test",
    "test:stdin": "npm run build && echo '{\"model\":{\"display_name\":\"Opus\"},\"context_window\":{\"current_usage\":{\"input_tokens\":45000},\"context_window_size\":200000},\"transcript_path\":\"/tmp/test.jsonl\"}' | node dist/index.js"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "hud"
  ],
  "author": "Jarrod Watts",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
